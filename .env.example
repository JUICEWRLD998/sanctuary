# Sanctuary — managed testnet signing keys (server-only).
# Copy to .env.local and fill with TESTNET private keys ONLY. Never mainnet.
# These are consumed by lib/env.ts and used by the orchestrator to sign real
# testnet transactions in senderKey mode. .env.local is gitignored.

# The app-run circle-escrow principal. This is the ONLY key the /create
# (real-user) flow needs — members sign their own joins with their own wallets.
ESCROW_KEY=

# The managed demo members that drive the seeded /circle/demo circle, in
# join / payout order. The app reads exactly CIRCLE.memberCount of these
# (currently 3 — see lib/constants.ts). Add MEMBER_4_KEY… only if you raise
# CIRCLE.memberCount to run a larger managed demo.
MEMBER_1_KEY=
MEMBER_2_KEY=
MEMBER_3_KEY=
