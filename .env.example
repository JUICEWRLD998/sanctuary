# Sanctuary — environment variables.
# Copy to .env.local and fill in your values. .env.local is gitignored.

# ── Storage ────────────────────────────────────────────────────────────────────
# Neon (serverless Postgres) connection string. When set, circles persist to the
# DB; when unset, they persist to JSON files under data/circles/ (local dev).
# Vercel's filesystem is read-only, so DATABASE_URL is REQUIRED in production for
# /create + open-circle joins to work. Connect a Neon database in the Vercel
# dashboard and it injects this automatically; for local testing paste it here.
# The two demo circles are bundled into the app (lib/seeds) and need no DB.
DATABASE_URL=

# Public site origin, used to build absolute OG/Twitter image URLs. Optional:
# on Vercel it falls back to the deployment's VERCEL_URL automatically. Set this
# to pin a custom production domain, e.g. https://sanctuary.example.com
NEXT_PUBLIC_SITE_URL=

# Shared secret protecting the automated bond-return sweep
# (GET|POST /api/cron/complete-due). A scheduler (cron-job.org / Vercel Cron)
# must send it as `Authorization: Bearer <secret>`. Generate a long random
# value, e.g.  openssl rand -hex 32  — without it the endpoint refuses to run.
CRON_SECRET=

# ── AI ─────────────────────────────────────────────────────────────────────────
# OpenRouter key — powers the Sanctuary AI chat (Gemini 2.0 Flash).
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── Managed testnet signing keys (server-only) ─────────────────────────────────
# TESTNET ONLY. These are consumed by lib/env.ts and used by the orchestrator
# to sign real testnet transactions in senderKey mode.

# The app-run circle-escrow principal. This is the ONLY key the /create
# (real-user) flow needs — members sign their own joins with their own wallets.
ESCROW_KEY=

# The managed demo members that drive the seeded /circle/demo circle, in
# join / payout order. The app reads exactly CIRCLE.memberCount of these
# (currently 3 — see lib/constants.ts). Add MEMBER_4_KEY… only if you raise
# CIRCLE.memberCount to run a larger managed demo.
MEMBER_1_KEY=
MEMBER_2_KEY=
MEMBER_3_KEY=
