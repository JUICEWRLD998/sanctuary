# Sanctuary — managed testnet signing keys (server-only).
# Copy to .env.local and fill with TESTNET private keys ONLY. Never mainnet.
# These are consumed by lib/env.ts and used by the orchestrator to sign real
# testnet transactions in senderKey mode. .env.local is gitignored.

# The app-run circle-escrow principal.
ESCROW_KEY=

# The six managed demo members (join / payout order 1..6).
MEMBER_1_KEY=
MEMBER_2_KEY=
MEMBER_3_KEY=
MEMBER_4_KEY=
MEMBER_5_KEY=
MEMBER_6_KEY=
